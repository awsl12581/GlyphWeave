{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://glyphweave.dev/schemas/gemap-v3-manifest.schema.json",
  "title": "GlyphWeave .gemap v3 manifest",
  "description": "The required root manifest.json entry of a GlyphWeave .gemap v3 ZIP container.",
  "type": "object",
  "required": [
    "format",
    "version",
    "world",
    "axisOrder",
    "chunkShape",
    "regionShape",
    "blockRegistry",
    "regions"
  ],
  "properties": {
    "format": {
      "const": "glyphweave-map"
    },
    "version": {
      "const": 3
    },
    "world": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "axisOrder": {
      "const": "z,x,y"
    },
    "chunkShape": {
      "type": "array",
      "prefixItems": [
        {
          "const": 16
        },
        {
          "const": 16
        },
        {
          "const": 16
        }
      ],
      "items": false,
      "minItems": 3
    },
    "regionShape": {
      "type": "array",
      "prefixItems": [
        {
          "const": "infinite"
        },
        {
          "const": 32
        },
        {
          "const": 32
        }
      ],
      "items": false,
      "minItems": 3
    },
    "blockRegistry": {
      "type": "object",
      "required": [
        "0"
      ],
      "properties": {
        "0": {
          "const": "glyphweave:air"
        }
      },
      "propertyNames": {
        "$ref": "#/$defs/uint32Key"
      },
      "additionalProperties": {
        "$ref": "#/$defs/blockName"
      }
    },
    "regions": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/regionKey"
      },
      "additionalProperties": {
        "$ref": "#/$defs/regionPath"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "not": {
    "anyOf": [
      {
        "required": [
          "tiles"
        ]
      },
      {
        "required": [
          "layerTiles"
        ]
      },
      {
        "required": [
          "layers"
        ]
      },
      {
        "required": [
          "tileSize"
        ]
      },
      {
        "required": [
          "themeId"
        ]
      }
    ]
  },
  "additionalProperties": true,
  "$defs": {
    "uint32Key": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]{0,8}|[1-3][0-9]{9}|4[01][0-9]{8}|42[0-8][0-9]{7}|429[0-3][0-9]{6}|4294[0-8][0-9]{5}|42949[0-5][0-9]{4}|429496[0-6][0-9]{3}|4294967[01][0-9]{2}|42949672[0-8][0-9]|429496729[0-5])$"
    },
    "blockName": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+:[a-z0-9_./-]+$"
    },
    "signedCoordinate": {
      "type": "string",
      "pattern": "^(?:0|-?[1-9][0-9]*)$"
    },
    "regionKey": {
      "type": "string",
      "pattern": "^(?:0|-?[1-9][0-9]*),(?:0|-?[1-9][0-9]*)$"
    },
    "regionPath": {
      "type": "string",
      "pattern": "^regions/(?:0|-?[1-9][0-9]*)\\.(?:0|-?[1-9][0-9]*)/region\\.json$"
    }
  }
}
