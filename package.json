{
  "name": "glyphweave",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server/index.mjs",
    "deploy": "pnpm run deploy:web",
    "deploy:web": "pnpm run build && wrangler deploy --config wrangler.jsonc",
    "deploy:bevy": "pnpm run bevy:web:build && wrangler deploy --config wrangler.bevy.jsonc",
    "preview": "pnpm run preview:web",
    "preview:web": "wrangler dev --config wrangler.jsonc",
    "preview:bevy": "pnpm run bevy:web:build && wrangler dev --config wrangler.bevy.jsonc",
    "lint": "oxlint",
    "perf:canvas": "node scripts/canvas-perf-benchmark.mjs",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "render-server": "node server/index.mjs",
    "doc-tree": "node scripts/generate-tree.mjs",
    "doc-tree:check": "node scripts/generate-tree.mjs --check",
    "bevy:fps": "bash scripts/check-bevy-fps.sh",
    "bevy:web:build": "bash scripts/build-bevy-web.sh",
    "bevy:web:deploy": "pnpm run deploy:bevy",
    "bevy:web:serve": "python3 -m http.server 8080 --directory bevy/web/dist"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.9",
    "@ai-sdk/openai-compatible": "^3.0.5",
    "@ai-sdk/react": "^4.0.19",
    "@fontsource-variable/geist": "^5.2.9",
    "@napi-rs/canvas": "^1.0.2",
    "@noble/hashes": "^2.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "ai": "^7.0.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-delaunay": "^6.0.4",
    "fflate": "^0.8.3",
    "i18next": "^25.1.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "immer": "^11.1.9",
    "konva": "^10.3.0",
    "lucide-react": "^1.23.0",
    "nanoid": "^5.1.16",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^15.6.1",
    "react-konva": "^19.2.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/d3-delaunay": "^6.0.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
